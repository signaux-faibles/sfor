<% content_for :title, 'Listes de détection' %>

<div class="fr-container">
  <nav role="navigation" class="fr-breadcrumb" aria-label="vous êtes ici :">
    <button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb">
      Voir le fil d'Ariane
    </button>
    <div class="fr-collapse" id="breadcrumb">
      <ol class="fr-breadcrumb__list">
        <li>
          <%= link_to 'Accueil', '/', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <a class="fr-breadcrumb__link" aria-current="page">Listes de détection</a>
        </li>
      </ol>
    </div>
  </nav>
</div>

<div class="fr-container fr-mt-5w fr-mb-5w">
  <div class="grid-row">
    <h1>Listes de détection</h1>

    <div class="fr-table--lg fr-table fr-table--bordered fr-table--no-caption" id="table-lg-component">
      <div class="fr-table__wrapper">
        <div class="fr-table__container">
          <div class="fr-table__content">
            <table id="table-lg">
              <caption>
                Toutes les listes
              </caption>
              <thead>
                <tr>
                  <th scope="col">Liste</th>
                  <th scope="col">Nombre d'entreprises</th>
                  <th scope="col">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if @lists.any? %>
                  <% @lists.each do |list| %>
                    <tr>
                      <th scope="row">
                        Liste de détection - <%= list.label %>
                      </th>
                      <td>
                        <%= turbo_frame_tag "list_company_count_#{list.id}",
                            src: company_count_list_path(list),
                            loading: "lazy" do %>
                          —
                        <% end %>
                      </td>
                      <td>
                        <%= link_to list_path(list),
                                    class: "fr-link",
                                    title: "Voir la liste de détection #{list.label}" do %>
                          <span class="fr-icon-eye-fill" aria-hidden="true"></span>
                          <span class="fr-sr-only">Voir la liste</span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="3" class="fr-text--center">
                      <p class="fr-mt-2w">Aucune liste disponible</p>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

