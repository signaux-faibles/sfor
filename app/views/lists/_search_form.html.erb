<div class="fr-card establishment_search">
  <%= form_with url: list_path(list), method: :get, scope: :search, class: "fr-search-bar", html: { class: "fr-search-bar__form" } do |f| %>
    <div class="fr-container--fluid fr-m-2w">
      <h2 class="fr-h4 fr-mt-1w">Filtrer les entreprises</h2>
      
      <!-- Database-based filters -->
      <div class="fr-grid-row fr-grid-row--gutters fr-mb-3w">
        <div class="fr-col-12 fr-col-lg-4">
          <div class="fr-input-group">
            <%= f.label :q, "SIREN / Raison sociale", class: "fr-label" %>
            <div class="fr-input-wrap fr-icon-search-line">
              <%= f.text_field :q, value: search_params[:q], class: "fr-input", placeholder: "SIREN ou raison sociale" %>
            </div>
          </div>
        </div>
        <div class="fr-col-12 fr-col-lg-4">
          <div class="fr-input-group">
            <%= f.label :departement_in, "Départements", class: "fr-label" %>
            <%= f.collection_select :departement_in, current_user.geo_access.departments.order(:code), :code, ->(d) { "#{d.code} - #{d.name}" }, { selected: search_params[:departement_in] }, { multiple: true, class: "tom-select", data: { controller: "tom-select" } } %>
          </div>
        </div>
        <div class="fr-col-12 fr-col-lg-4">
          <div class="fr-input-group">
            <%= f.label :effectif_min, "Effectif min. de l'entreprise", class: "fr-label" %>
            <%= f.number_field :effectif_min, value: search_params[:effectif_min], class: "fr-input", placeholder: "Nombre minimum d'employés", min: 0, step: 1 %>
          </div>
        </div>
      </div>



      <!-- Database-based filters -->

      <div data-controller="filters-toggle">
        <%= f.hidden_field :filters_open,
                           value: params.dig(:search, :filters_open) || "false",
                           id: "filters_open",
                           data: { filters_toggle_target: "filtersOpenInput" } %>
        <div data-filters-toggle-target="hiddenFilters" style="display: <%= params.dig(:search, :filters_open) == "true" ? "block" : "none" %>">
          <div class="fr-grid-row fr-grid-row--gutters fr-mb-3w">
            <div class="fr-col-12 fr-col-lg-4">
              <div class="fr-input-group">
                <%= f.label :section_activite_principale, "Secteur d'activité", class: "fr-label" %>
                <%= f.select :section_activite_principale,
                             [
                               ["A - Agriculture, sylviculture et pêche", "A"],
                               ["B - Industries extractives", "B"],
                               ["C - Industrie manufacturière", "C"],
                               ["D - Production et distribution d'électricité, de gaz, de vapeur et d'air conditionné", "D"],
                               ["E - Production et distribution d'eau ; assainissement, gestion des déchets et dépollution", "E"],
                               ["F - Construction", "F"],
                               ["G - Commerce ; réparation d'automobiles et de motocycles", "G"],
                               ["H - Transports et entreposage", "H"],
                               ["I - Hébergement et restauration", "I"],
                               ["J - Information et communication", "J"],
                               ["K - Activités financières et d'assurance", "K"],
                               ["L - Activités immobilières", "L"],
                               ["M - Activités spécialisées, scientifiques et techniques", "M"],
                               ["N - Activités de services administratifs et de soutien", "N"],
                               ["O - Administration publique", "O"],
                               ["P - Enseignement", "P"],
                               ["Q - Santé humaine et action sociale", "Q"],
                               ["R - Arts, spectacles et activités récréatives", "R"],
                               ["S - Autres activités de services", "S"],
                               ["T - Activités des ménages en tant qu'employeurs ; activités indifférenciées des ménages en tant que producteurs de biens et services pour usage propre", "T"],
                               ["U - Activités extra-territoriales", "U"]
                             ],
                             { selected: search_params[:section_activite_principale] },
                             { multiple: true, class: "tom-select", data: { controller: "tom-select" } } %>
              </div>
            </div>
            <div class="fr-col-12 fr-col-lg-4">
              <div class="fr-input-group">
                <%= f.label :forme_juridique, "Forme juridique", class: "fr-label" %>
                <%= f.select :forme_juridique,
                             legal_forms_options.map { |code, label| ["#{code} - #{label}", code] },
                             { selected: search_params[:forme_juridique] },
                             { multiple: true, class: "tom-select", data: { controller: "tom-select" } } %>
              </div>
            </div>
          </div>

          <div class="fr-grid-row fr-grid-row--gutters fr-mb-3w">
            <div class="fr-col-12 fr-col-lg-4">
              <div class="fr-input-group">
                <div class="sf-label--tooltip">
                  <%= f.label :dette_sociale_min, "Montant de la dette sociale min.", class: "fr-label" %>
                  <span id="sf-dette-sociale-infobulle">
                    <button aria-describedby="tooltip-dette-sociale-min" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
                    <span class="fr-tooltip fr-placement" id="tooltip-dette-sociale-min" role="tooltip">Minimum du cumul de la dette sociale (part patronale et part salariale) sur le mois dernier.</span>
                  </span>
                </div>
                <%=
                  f.number_field :dette_sociale_min,
                                 value: search_params[:dette_sociale_min],
                                 class: "fr-input",
                                 placeholder: "Montant minimum",
                                 min: 0,
                                 step: 1000,
                                 aria: { describedby: "sf-dette-sociale-infobulle" }
                %>
              </div>
            </div>
            <div class="fr-col-12 fr-col-lg-4">
              <div class="fr-input-group">
                <%= f.label :libelle_procol, "Statut de procédure collective", class: "fr-label" %>
                <%= f.select :libelle_procol,
                             [
                               ["Tous", ""],
                               ["In bonis", "In bonis"],
                               ["Redressement judiciaire", "Redressement judiciaire"],
                               ["Plan de redressement", "Plan de redressement"],
                               ["Sauvegarde", "Sauvegarde"],
                               ["Plan de sauvegarde", "Plan de sauvegarde"],
                               ["Liquidation judiciaire", "Liquidation judiciaire"],
                             ],
                             { selected: search_params[:libelle_procol] || "" },
                             { class: "fr-select" } %>
              </div>
            </div>
            <div class="fr-col-12 fr-col-lg-4">
              <div class="fr-input-group">
                <%= f.label :niveau_alerte, "Niveau d'alerte", class: "fr-label" %>
                <%= f.select :niveau_alerte,
                             [
                               ["Tous", ""],
                               ["Alerte élevée", "Alerte seuil F1"],
                               ["Alerte modérée", "Alerte seuil F2"]
                             ],
                             { selected: search_params[:niveau_alerte] || "" },
                             { class: "fr-select" } %>
              </div>
            </div>
          </div>

          <div class="fr-grid-row fr-grid-row--gutters fr-mb-3w">

            <div class="fr-col-12">
              <div class="fr-checkbox-group sf-checkbox-group--tooltip">
                <%= f.check_box :premieres_alertes,
                                { checked: search_params[:premieres_alertes] == "1",
                                  aria: { describedby: "sf-premieres-alertes-infobulle" }},
                                "1",
                                "0"
                %>

                <%= f.label :premieres_alertes, "Premières alertes", class: "fr-label" %>
                <span id="sf-premieres-alertes-infobulle">
                  <button aria-describedby="tooltip-premieres-alertes" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
                  <span class="fr-tooltip fr-placement" id="tooltip-premieres-alertes" role="tooltip">Affiche uniquement les entreprises en alerte pour la première fois.</span>
                </span>

              </div>
            </div>
            <div class="fr-col-12">
              <div class="fr-checkbox-group sf-checkbox-group--tooltip">
                <%=
                  f.check_box :sans_entreprises_recentes,
                              { checked: search_params[:sans_entreprises_recentes] == "1",
                                aria: { describedby: "sf-sans-entreprises-recentes-infobulle" }},
                              "1",
                              "0"
                %>
                <%= f.label :sans_entreprises_recentes, "Sans entreprises récentes", class: "fr-label" %>
                <span id="sf-sans-entreprises-recentes-infobulle">
                  <button aria-describedby="tooltip-sans-entreprises-recentes" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
                  <span class="fr-tooltip fr-placement" id="tooltip-sans-entreprises-recentes" role="tooltip">Affiche uniquement les entreprises créées avant le 20 septembre 2023.</span>
                </span>
              </div>
            </div>
            <div class="fr-col-12">
              <div class="fr-checkbox-group sf-checkbox-group--tooltip">
                <%=
                  f.check_box :sans_delai_urssaf,
                              { checked: search_params[:sans_delai_urssaf] == "1",
                                aria: { describedby: "sf-sans-delai-paiement-urssaf-infobulle" }},
                              "1",
                              "0"
                %>
                <%= f.label :sans_delai_urssaf, "Sans délai de paiement URSSAF", class: "fr-label" %>
                <span id="sf-sans-delai-paiement-urssaf-infobulle">
                  <button aria-describedby="tooltip-sans-delai-paiement-urssaf-infobulle" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
                  <span class="fr-tooltip fr-placement" id="tooltip-sans-delai-paiement-urssaf-infobulle" role="tooltip">Affiche uniquement les entreprises ne bénéficiant pas de délai de paiement Urssaf sur le dernier mois.</span>
                </span>
              </div>
            </div>
            <% if list.sjcf_filter_active? %>
              <div class="fr-col-12">
                <div class="fr-checkbox-group sf-checkbox-group--tooltip">
                  <%=
                    f.check_box :liste_retraitee,
                                  { checked: search_params[:liste_retraitee] == "1",
                                    aria: { describedby: "sf-liste-retraitee-infobulle" }},
                                  "1",
                                  "0"
                  %>

                  <%= f.label :liste_retraitee, class: "fr-label" do %>
                    Liste retraitée
                  <% end %>

                  <span id="sf-liste-retraitee-infobulle">
                    <button aria-describedby="tooltip-liste-retraitee" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
                    <span class="fr-tooltip fr-placement" id="tooltip-liste-retraitee" role="tooltip">Affiche uniquement la liste transmise au CDED en amont de la réunion du CODEFI</span>
                  </span>

                </div>
              </div>
            <% end %>
          </div>

        </div>
        <div class="fr-grid-row fr-grid-row--right fr-mt-5w">
          <ul class="fr-btns-group fr-btns-group--center fr-btns-group--inline-lg fr-btns-group--icon-left">
            <li>
              <%= button_tag type: "button",
                             class: "fr-btn fr-btn--tertiary fr-btn--icon-left",
                             data: { action: "filters-toggle#toggle", filters_toggle_target: "toggleButton" } do %>
                <span class="<%= params.dig(:search, :filters_open) == "true" ? 'fr-icon-arrow-up-line' : 'fr-icon-arrow-down-line' %>" aria-hidden="true"></span>
                <%= params.dig(:search, :filters_open) == "true" ? 'Réduire les critères supplémentaires' : 'Afficher des critères supplémentaires' %>
              <% end %>
            </li>
            <li>
              <%= link_to "Réinitialiser les filtres", list_path(list), class: "fr-btn fr-icon-restart-line fr-btn--secondary", data: { turbo: false} %>
            </li>
            <li>
              <%= f.submit "Rechercher", class: "fr-btn" %>
            </li>
          </ul>
        </div>
      </div>
    </div>
  <% end %>
</div>
