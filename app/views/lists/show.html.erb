<div class="fr-container">
  <nav role="navigation" class="fr-breadcrumb" aria-label="vous êtes ici :">
    <button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb">
      Voir le fil d'Ariane
    </button>
    <div class="fr-collapse" id="breadcrumb">
      <ol class="fr-breadcrumb__list">
        <li>
          <%= link_to 'Accueil', '/', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <%= link_to 'Listes de détection', '/listes', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <a class="fr-breadcrumb__link" aria-current="page">Liste <%= @list.label %></a>
        </li>
      </ol>
    </div>
  </nav>
</div>

<div class="fr-container fr-mt-5w fr-mb-5w">
  <div class="grid-row">
    <h1><%= @list.label %></h1>
    <p class="fr-text--lg fr-mb-3w">
      Code: <strong><%= @list.code %></strong> • 
      <%= pluralize(@list.company_score_entries.select(:siren).distinct.count, "entreprise", "entreprises") %>
    </p>

    <%= render 'search_form', search_params: @search_params || {}, list: @list %>

    <h2 class="fr-mt-5w">Résultats de recherche</h2>

    <% if @results && @results.any? %>
      <div class="fr-grid-row fr-grid-row--gutters fr-mb-2w">
        <div class="fr-col-12">
          <%= link_to list_path(@list, search: @search_params, format: :xlsx),
                      class: 'fr-link--download fr-link',
                      data: { controller: 'download', action: 'click->download#disable', download_target: 'button' },
                      id: 'download-button' do %>
            Télécharger les <%= @pagination[:total_results] %> résultats de la recherche
            <span class="fr-link__detail">XLS</span>
          <% end %>
        </div>
      </div>
      <p class="fr-mt-2w">
        <%= pluralize(@pagination[:total_results], "entreprise", "entreprises") %>
        <% if @alert_breakdown %>
          • 
          <span class="fr-badge fr-badge--error fr-badge--no-icon">
            <%= @alert_breakdown[:alerte_elevee] %> <%= @alert_breakdown[:alerte_elevee] > 1 ? "Alertes élevées" : "Alerte élevée" %>
          </span>
          et
          <span class="fr-badge fr-badge--pink-macaron">
            <%= @alert_breakdown[:alerte_moderee] %> <%= @alert_breakdown[:alerte_moderee] > 1 ? "Alertes modérées" : "Alerte modérée" %>
          </span>
        <% end %>
        <% if @pagination[:total_pages] > 1 %>
          <br>
          Page <%= @pagination[:page] %> sur <%= @pagination[:total_pages] %>
        <% end %>
      </p>

      <div class="fr-mt-3w">
        <div class="fr-grid-row fr-grid-row--gutters">
          <% @results.each do |company| %>
            <div class="fr-col-12">
              <div class="fr-card fr-enlarge-link fr-card--sm">
                <div class="fr-card__body">
                  <div class="fr-card__content">
                    <h3 class="fr-card__title">
                      <%= link_to company["nom_complet"], company_path(company["siren"]) %>
                    </h3>
                    <p class="fr-card__desc">
                      SIREN : <%= company["siren"] %>
                    </p>
                    <div class="fr-card__start">
                      <ul class="fr-badges-group">
                        <% if company["has_tracking_in_progress"] %>
                          <li>
                            <p class="fr-badge fr-badge--info">Accompagnement en cours</p>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                    <% if company["nombre_etablissements_ouverts"] %>
                      <div class="fr-card__end">
                        <p class="fr-card__detail fr-icon-building-4-line">
                          <%= pluralize(company["nombre_etablissements_ouverts"], "établissement", "établissements") %> en activité
                        </p>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <% if @pagination[:total_pages] > 1 %>
        <div class="fr-grid-row fr-grid-row--center">
          <nav class="fr-pagination fr-mt-4w" role="navigation" aria-label="Pagination">
            <ul class="fr-pagination__list">
              <% if @pagination[:page] > 1 %>
                <li>
                  <%= link_to list_path(@list, search: @search_params.merge(page: @pagination[:page] - 1)),
                              class: "fr-pagination__link fr-pagination__link--prev",
                              "aria-disabled": "false",
                              rel: "prev" do %>
                    Page précédente
                  <% end %>
                </li>
              <% end %>

              <% max_pages_to_show = 5 %>
              <% start_page = [@pagination[:page] - 2, 1].max %>
              <% end_page = [start_page + max_pages_to_show - 1, @pagination[:total_pages]].min %>

              <% (start_page..end_page).each do |page_num| %>
                <li>
                  <%= link_to page_num,
                              list_path(@list, search: @search_params.merge(page: page_num)),
                              class: "fr-pagination__link #{'fr-pagination__link--current' if page_num == @pagination[:page]}",
                              "aria-current": (page_num == @pagination[:page] ? "page" : nil),
                              title: "Page #{page_num}" %>
                </li>
              <% end %>

              <% if @pagination[:page] < @pagination[:total_pages] %>
                <li>
                  <%= link_to list_path(@list, search: @search_params.merge(page: @pagination[:page] + 1)),
                              class: "fr-pagination__link fr-pagination__link--next",
                              "aria-disabled": "false",
                              rel: "next" do %>
                    Page suivante
                  <% end %>
                </li>
              <% end %>
            </ul>
          </nav>
        </div>
      <% end %>
    <% else %>
      <div class="fr-alert fr-alert--info fr-mt-3w">
        <p>Aucun résultat trouvé.</p>
      </div>
    <% end %>
  </div>
</div>

