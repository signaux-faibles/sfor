<% content_for :title, "Liste #{@list.label}" %>

<div class="fr-container">
  <nav role="navigation" class="fr-breadcrumb" aria-label="vous êtes ici :">
    <button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb">
      Voir le fil d'Ariane
    </button>
    <div class="fr-collapse" id="breadcrumb">
      <ol class="fr-breadcrumb__list">
        <li>
          <%= link_to 'Accueil', '/', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <%= link_to 'Listes de détection', '/listes', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <a class="fr-breadcrumb__link" aria-current="page">Liste <%= @list.label %></a>
        </li>
      </ol>
    </div>
  </nav>
</div>

<div class="fr-container fr-mt-5w fr-mb-5w">
  <div class="grid-row">
    <h1>Liste <%= @list.label %></h1>

    <%= render 'search_form', search_params: @search_params || {}, list: @list %>

    <h2 class="fr-mt-5w">Résultats de recherche</h2>

    <% if @results && @results.any? %>
      <div class="fr-grid-row fr-grid-row--gutters fr-mb-2w">
        <div class="fr-col-12" role="status">
          <%= link_to list_path(@list, search: @search_params, format: :xlsx),
                      class: 'fr-link--download fr-link',
                      data: { controller: 'download', action: 'click->download#disable', download_target: 'button' },
                      id: 'download-button' do %>
            Télécharger les résultats de la recherche
            <span class="fr-link__detail">(6 Mo, XLS)</span>
          <% end %>
        </div>
      </div>
      <p class="fr-mt-2w">
        <%= turbo_frame_tag "alert_breakdown", 
            src: alert_breakdown_list_path(@list, search: @search_params),
            loading: "lazy" do %>
          <!-- Loading total count and alert breakdown... -->
        <% end %>
      </p>

      <div class="fr-mt-3w">
        <div class="fr-grid-row fr-grid-row--gutters" id="companies-container">
          <%= render partial: "company_card", collection: @results, as: :company, locals: { list: @list } %>
        </div>
      </div>

      <% if @has_next_page && @next_cursor %>
        <div class="fr-grid-row fr-grid-row--center fr-mt-4w" id="load-more-container">
          <%= link_to "Charger plus de résultats",
                      load_more_list_path(@list, search: @search_params.merge(cursor: @next_cursor), format: :turbo_stream),
                      class: "fr-btn fr-btn--secondary",
                      data: { turbo_stream: true } %>
        </div>
      <% end %>

    <% else %>
      <div class="fr-alert fr-alert--info fr-mt-3w">
        <p>Aucun résultat trouvé.</p>
      </div>
    <% end %>
  </div>
</div>

