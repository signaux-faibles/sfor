<%= turbo_frame_tag "establishment_trackings_list_widget" do %>
  <h2>Accompagnements</h2>
  <% if @in_progress_trackings.empty? and @completed_trackings.empty? %>
    <p>Aucun accompagnement en cours.</p>

    <%= link_to "Créer un accompagnement",
                new_establishment_establishment_tracking_path(@establishment),
                class: "fr-btn fr-btn--secondary",
                data: { turbo: false }
    %>
  <% else %>
    <% if !@in_progress_trackings.present? %>
      <div class="fr-notice fr-notice--info">
        <div class="fr-container">
          <div class="fr-notice__body">
            <p>
              <span class="fr-notice__title">Aucun accompagnement en cours actuellement.</span>
            </p>
          </div>
        </div>
      </div>
    <% end %>

    <div class="fr-table fr-table--no-caption fr-table--bordered fr-table--no-scroll fr-table--multiline" id="sf-trackings-table">
      <div class="fr-table__wrapper">
        <div class="fr-table__container">
          <div class="fr-table__content">
            <table id="table-0">
              <caption>Accompagnements</caption>
              <thead>
              <tr>
                <th scope="col">Date de début</th>
                <th scope="col">Date de fin</th>
                <th scope="col">Criticité</th>
                <th scope="col">Référents</th>
                <th scope="col">Date de dernière modification</th>
                <th scope="col">Actions réalisées</th>
                <th scope="col">Actions</th>
              </tr>
              </thead>
              <tbody>

              <% @in_progress_trackings.each do |tracking| %>
                <tr class="sf-in-progress-tracking fr-text--lg">
                  <%= render partial: "establishment_trackings_row", locals: { tracking: tracking } %>
                </tr>
              <% end %>

              <% @completed_trackings.each do |tracking| %>
                <tr>
                  <%= render partial: "establishment_trackings_row", locals: { tracking: tracking } %>
                </tr>
              <% end %>


              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>




