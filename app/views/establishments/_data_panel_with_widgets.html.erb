<div id="tabpanel-data-panel"
     class="fr-tabs__panel"
     role="tabpanel"
     aria-labelledby="tabpanel-data"
     tabindex="0">
  <h2 class="fr-sr-only">Données de l'établissement</h2>
  <div class="fr-grid-row fr-grid-row--gutters">
    <!-- Effectif / AP Widget with Turbo Frame -->
    <div class="fr-col-12">
      <div class="fr-card">
        <div class="fr-card__body">
          <div class="fr-card__content">
            <%= turbo_frame_tag "data_effectif_ap_widget",
                                src: data_effectif_ap_widget_establishment_path(@establishment),
                                loading: :lazy do %>
              <h3 class="fr-h2">Effectifs / Activité partielle</h3>
              <p class="fr-mt-2w">Récupération des données...</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- URSSAF Widget with Turbo Frame -->
    <div class="fr-col-12">
      <div class="fr-card">
        <div class="fr-card__body">
          <div class="fr-card__content">
            <%= turbo_frame_tag "data_urssaf_widget",
                                src: data_urssaf_widget_establishment_path(@establishment),
                                loading: :lazy do %>
              <h3 class="fr-h2">Cotisations, impayés et délais de paiement URSSAF</h3>
              <p class="fr-mt-2w">Récupération des données...</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
