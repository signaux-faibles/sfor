<td>
  <% if tracking.state.present? %>
    <%= content_tag :p, state_wording_for(tracking.state), { class: badge_class_for(tracking.state) } %>
  <% end %>
</td>
<td>
  <% if tracking.criticality.present? %>
    <%= content_tag :p, tracking.criticality.name, { class: criticality_class_for(tracking.criticality.name) } %>
  <% end %>
</td>
<td>
  <% if tracking.referents.any? %>
    <% first_referent = tracking.referents.first %>
    <span title="<%= tracking.referents.map(&:full_name).join(', ') %>">
      <%= truncate(first_referent.full_name, length: 20) %>
    </span>
    <% if tracking.referents.size > 1 %>
      <span>+<%= tracking.referents.size - 1 %></span>
    <% end %>
  <% else %>
    <span>Aucun référent</span>
  <% end %>
</td>
<td>
  <%= tracking.modified_at.present? ? l(tracking.modified_at, format: :default) : '-' %>
</td>
<td>
  <% if tracking.user_actions.kept.any? %>
    <% tracking.user_actions.kept.ordered.each do |action| %>
      <%= content_tag :span, action.name, class: "fr-tag fr-tag--sm" %>
    <% end %>
  <% else %>
    <span>Non renseigné</span>
  <% end %>
</td>
<td>
  <%= link_to [tracking.establishment, tracking],
              class: 'fr-link',
              title: "Consulter #{tracking.establishment.raison_sociale}",
              aria_label: "Consulter #{tracking.establishment.raison_sociale}",
              data: { turbo: false } do %>
    <span class="fr-icon-eye-fill" aria-hidden="true"></span>
    <span class="fr-sr-only">Consulter <%= tracking.establishment.raison_sociale %></span>
  <% end %>
</td>