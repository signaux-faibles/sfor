<div class="fr-container">
  <nav role="navigation" class="fr-breadcrumb" aria-label="vous êtes ici :">
    <button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb">
      Voir le fil d'Ariane
    </button>
    <div class="fr-collapse" id="breadcrumb">
      <ol class="fr-breadcrumb__list">
        <li>
          <%= link_to 'Accueil', '/', class: 'fr-breadcrumb__link' %>
        </li>
        <li>
          <a class="fr-breadcrumb__link" aria-current="page">Établissement <%= @establishment.raison_sociale %></a>
        </li>
      </ol>
    </div>
  </nav>
</div>
<div>
  <div class="fr-pb-4w fr-pt-4w sf-alt-background sf-title-above-tabs">
    <div class="fr-container sf-fiche-title">
      <h1>Fiche établissement — <%= @establishment.raison_sociale %></h1>
    </div>
  </div>

  <div class="fr-container">
    <div class="fr-tabs">
      <ul class="fr-tabs__list sf-alt-background fr-pb-0" role="tablist" aria-label="Informations sur l'entreprise">
        <!-- Company Information Tab -->
        <li role="presentation">
          <button id="tabpanel-informations"
                  type="button"
                  class="fr-tabs__tab"
                  tabindex="0" role="tab"
                  aria-selected="true"
                  aria-controls="tabpanel-informations-panel">
            Informations générales
          </button>
        </li>

        <li role="presentation">
          <button id="tabpanel-data"
                  type="button"
                  class="fr-tabs__tab"
                  tabindex="-1" role="tab"
                  aria-selected="false"
                  aria-controls="tabpanel-data-panel">
            Données de l'établissement
          </button>
        </li>

        <li role="presentation">
          <button id="tabpanel-helps"
                  type="button"
                  class="fr-tabs__tab"
                  tabindex="-1" role="tab"
                  aria-selected="false"
                  aria-controls="tabpanel-helps-panel">
            Accompagnements
          </button>
        </li>
      </ul>

      <%= render 'info_panel_with_widgets' %>
      <%= render 'data_panel_with_widgets' %>
      <%= render 'establishment_trackings_list_panel' %>

    </div>
  </div>
</div>