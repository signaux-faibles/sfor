<%= turbo_frame_tag "establishments_widget" do %>
  <div class="fr-grid-row fr-grid-row--gutters">
    <div class="fr-col-12">
      <div class="sf-entreprise-subtitle fr-mb-3w">
        <h2 class="fr-mb-0">
          Liste des établissements
        </h2>

        <div>
          <button aria-describedby="tooltip-liste-etab" type="button" class="fr-btn--tooltip fr-btn">infobulle</button>
          <div class="fr-tooltip fr-placement" id="tooltip-liste-etab" role="tooltip">
            <p class="fr-text--xs fr-mb-0">Liste indiquant le siège social et les établissements secondaires. Ces données sont issues de la base Sirene des entreprises et de leurs établissements produite par l’Insee.</p>
          </div>
        </div>
      </div>

      <% if @enriched_establishments&.any? %>
        <div class="fr-col-12 fr-col-xl-8">
          <div class="fr-notice fr-notice--info">
            <div class="fr-container">
              <div class="fr-notice__body">
                <p>
                  <span class="fr-notice__title">Cette structure possède <%= @total_establishments || 0 %> établissement<%= 's' if (@total_establishments || 0) > 1 %> dont <%= @active_establishments || 0 %> <%= (@active_establishments || 0) > 1 ? 'sont' : 'est' %> en activité.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @enriched_establishments&.any? %>
    <% 
      # Utiliser les établissements enrichis (Rails + INSEE)
      all_establishments = @enriched_establishments
    %>
    <div class="fr-table fr-table--no-caption fr-table--bordered">
      <div class="fr-table__wrapper">
        <div class="fr-table__container">
          <div class="fr-table__content">
            <table>
              <caption>Liste des établissements</caption>
              <thead>
                <tr>
                  <th scope="col">SIRET</th>
                  <th scope="col">Département</th>
                  <th scope="col"><abbr title="Effectif établissement">Eff. établissement</abbr></th>
                  <th scope="col">Dette sociale</th>
                  <th scope="col">Activité partielle</th>
                  <th scope="col">État</th>
                  <th scope="col">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% all_establishments.each do |enriched_establishment| %>
                  <% rails_data = enriched_establishment[:rails_data] %>

                  <tr>
                    <th scope="row">
                      <% if rails_data.present? %>
                        <strong>
                          <%=
                            rails_data.siret
                          %>
                        </strong>

                        <% if rails_data.siege %>
                          <p class="fr-badge fr-ml-1w">Siège social</p>
                        <% end %>
                      <% end %>

                    </th>
                    
                    <td>
                      <% if rails_data.present? %>
                        <%= rails_data.department&.name %>
                      <% end %>
                    </td>
                    
                    <td>
                      <% if enriched_establishment[:last_effectif].present? %>
                        <%= enriched_establishment[:last_effectif] %>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    
                    <td>
                      <% if enriched_establishment[:active_dette_urssaf] == true %>
                        <p class="fr-badge fr-badge--sm fr-badge--error fr-badge--no-icon">Oui</p>
                      <% elsif enriched_establishment[:active_dette_urssaf] == "Na" %>
                        <p class="fr-badge fr-badge--sm">N/A</p>
                      <% else %>
                        <p class="fr-badge fr-badge--sm fr-badge--success fr-badge--no-icon">Non</p>
                      <% end %>
                    </td>
                    
                    <td>
                      <% if enriched_establishment[:active_activite_partielle] == true %>
                        <p class="fr-badge fr-badge--sm fr-badge--error fr-badge--no-icon">Oui</p>
                      <% else %>
                        <p class="fr-badge fr-badge--sm fr-badge--success fr-badge--no-icon">Non</p>
                      <% end %>
                    </td>

                    <td>
                      <% if enriched_establishment[:etat_administratif] == "F" && enriched_establishment[:date_fermeture_formatted].present? %>
                        <p class="fr-badge fr-badge--pink-macaron fr-badge--sm">Fermé le <%= enriched_establishment[:date_fermeture_formatted] %></p>
                      <% elsif enriched_establishment[:etat_administratif] == "A" %>
                        <p class="fr-badge fr-badge--sm fr-badge--success fr-badge--no-icon">En activité</p>
                      <% else %>
                        <p class="fr-badge fr-badge--sm">-</p>
                      <% end %>
                    </td>
                    <td>
                      <%= link_to "/etablissements/#{rails_data.siret}",
                                  class: "fr-link",
                                  title: "Consulter #{rails_data.raison_sociale} (#{rails_data.siret})",
                                  data: { turbo_frame: "_top" } do %>
                        <span class="fr-icon-eye-fill" aria-hidden="true"></span>
                        <span class="fr-sr-only">Consulter <%= rails_data.raison_sociale %> (<%= rails_data.siret %>)</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="fr-mt-3w fr-mb-3w">
      <%= paginate @paginated_establishments %>
    </div>
  <% else %>
    <div class="fr-col-12 fr-col-xl-8">
      <div role="notice" class="fr-notice fr-notice--alert">
        <div class="fr-container">
          <div class="fr-notice__body">
            <p>
              <span class="fr-notice__title">Erreur lors de la récupération des établissements</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
