<!-- Establishment Information Panel -->
<div id="tabpanel-informations-panel"
     class="fr-tabs__panel fr-tabs__panel--selected"
     role="tabpanel"
     aria-labelledby="tabpanel-informations"
     tabindex="0">
  <h2 class="fr-sr-only">Informations</h2>
  <div>
    <div class="fr-grid-row fr-grid-row--gutters">
      <div class="fr-col-6">
        <%= render(TrackingInfoComponent.new(establishment_tracking: @establishment_tracking, establishment: @establishment_tracking.establishment, current_user: current_user)) %>

        <%= render(EstablishmentInfoComponent.new(establishment_tracking: @establishment_tracking, establishment: @establishment_tracking.establishment, current_user: current_user)) %>

        <%= render 'establishment_trackings/info_panel/contacts_list', establishment: @establishment, establishment_tracking: @establishment_tracking %>
      </div>

      <div class="fr-col-6">
        <%= render ContributorsInfoComponent.new(establishment_tracking: @establishment_tracking, establishment: @establishment, current_user: current_user) %>

        <div class="fr-grid-row">
          <div class="fr-card fr-col-12 fr-mt-3w">
            <div class="fr-card__body">
              <div class="fr-card__content">
                <h3 class="fr-h2">Consulter les informations complémentaires</h3>
                <ul>
                  <li>
                    <%= link_to [@establishment_tracking.establishment],
                                class: 'fr-link',
                                data: { turbo: false } do %>
                      Consulter la fiche établissement
                    <% end %>
                  </li>
                  <li>
                    <%= link_to "Consulter la fiche entreprise",
                                company_path(siren: @establishment_tracking.establishment.siren),
                                class: 'fr-link',
                                target: "_self" %>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%= render 'establishment_trackings/info_panel/tracking_history' %>
    <%= render 'establishment_trackings/info_panel/company_trackings' %>
  </div>
</div>